FROM node:20-slim

# Install Puppeteer dependencies
RUN apt-get update && apt-get install -y \
    wget \
    gnupg \
    ca-certificates \
    procps \
    libnss3 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdrm2 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpangocairo-1.0-0 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcursor1 \
    libxi6 \
    libxtst6 \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package*.json ./
# Tell Puppeteer to download Chrome to the app directory
ENV PUPPETEER_CACHE_DIR=/app/.cache
RUN npm install
COPY . .

# Explicitly install Chrome to ensure it's present
RUN npx puppeteer browsers install chrome

# Give the non-root node user permission to read the downloaded browser
RUN chown -R node:node /app

# Set environment variable for Puppeteer
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

USER node
EXPOSE 3001
CMD ["npm", "start"]
